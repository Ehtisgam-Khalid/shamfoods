rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'role', 'email']) &&
               data.uid == request.auth.uid &&
               data.role in ['user', 'admin', 'rider'] &&
               data.email is string && data.email.size() <= 100;
      }

      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'user';
      allow update: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      incoming().role == existing().role &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'photoURL']);
    }

    // --- Products Collection ---
    match /products/{productId} {
      allow read: if true; // Everyone can see the menu
      
      function isValidProduct(data) {
        return data.title is string && data.title.size() <= 100 &&
               data.price is number && data.price >= 0 &&
               data.category is string;
      }

      allow create, update, delete: if isAdmin() && isValidProduct(incoming());
    }

    // --- Categories Collection ---
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Orders Collection ---
    match /orders/{orderId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (
        (request.query.limit <= 50 && resource.data.userId == request.auth.uid) || 
        isAdmin()
      );

      function isValidOrder(data) {
        return data.userId == request.auth.uid &&
               data.total is number && data.total >= 0 &&
               data.status in ['pending', 'accepted', 'preparing', 'out_for_delivery', 'delivered', 'cancelled'] &&
               data.items is list && data.items.size() > 0;
      }

      allow create: if isSignedIn() && isValidOrder(incoming());
      
      allow update: if isSignedIn() && (
        // Admin can update status
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'paymentStatus'])) ||
        // User can only cancel OR update nothing (heartbeat)
        (isOwner(existing().userId) && 
         existing().status == 'pending' && 
         incoming().status == 'cancelled' &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
      );
    }
  }
}
